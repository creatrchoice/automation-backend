# ===== Instagram DM Automation - Environment Variables =====

# Instagram OAuth (from Meta Developer Dashboard)
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret
INSTAGRAM_REDIRECT_URI=https://your-domain.com/auth/instagram/callback
WEBHOOK_VERIFY_TOKEN=your-random-webhook-verify-token

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Azure Cosmos DB
AZURE_COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
AZURE_COSMOS_KEY=your-cosmos-primary-key
DM_DATABASE_NAME=dm_automation_db
DM_USERS_CONTAINER=users
DM_IG_ACCOUNTS_CONTAINER=instagram_accounts
DM_AUTOMATIONS_CONTAINER=automations
DM_CONTACTS_CONTAINER=contacts
DM_MESSAGE_LOGS_CONTAINER=message_logs
DM_ANALYTICS_CONTAINER=analytics_daily
DM_WEBHOOK_EVENTS_CONTAINER=webhook_events
DM_SCHEDULED_TASKS_CONTAINER=scheduled_tasks

# Azure Key Vault (optional for dev — Fernet fallback below is sufficient)
AZURE_KEY_VAULT_URL=https://your-keyvault.vault.azure.net/
# Falls back to AES-256-GCM encryption if Key Vault is not configured
ENCRYPTION_KEY=your-32-byte-base64-encoded-key

# Azure Service Bus (webhook message queue - optional, falls back to Redis)
AZURE_SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://your-namespace.servicebus.windows.net/;SharedAccessKeyName=...
AZURE_SERVICE_BUS_QUEUE_NAME=instagram-webhooks

# Azure Blob Storage (frontend direct upload URLs)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=dm-media
AZURE_STORAGE_SAS_EXPIRY_MINUTES=15

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_SSL=false

# DM Rate Limiting
DM_RATE_LIMIT_PER_HOUR=200
DEDUP_TTL_HOURS=24

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Application
ENVIRONMENT=development
DEBUG=true

# Webhook processing flags
# false by default: queue service path is disabled unless explicitly enabled
ENABLE_WEBHOOK_QUEUE_SERVICE=false
# true by default: process each webhook immediately when received
# (if queue is also enabled, webhook processing happens both on receive and on queue-consume)
ENABLE_WEBHOOK_INLINE_FALLBACK_ON_RECEIVE=true
